{
  "name": "bukolabs-pos-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@nestjs/common": "10.4.20",
    "@nestjs/config": "3.3.0",
    "@nestjs/core": "10.4.20",
    "@nestjs/platform-express": "10.4.20",
    "bcrypt": "5.1.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "dotenv": "16.4.7",
    "pg": "8.13.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1"
  },
  "devDependencies": {
    "@types/bcrypt": "5.0.2",
    "@types/node": "22.13.10",
    "@types/pg": "8.11.11",
    "prettier": "3.5.3",
    "ts-node-dev": "2.0.0",
    "typescript": "5.8.3"
  }
